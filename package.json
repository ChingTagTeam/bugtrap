{
  "name": "bugtrap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--experimental-require-module next dev",
    "build": "cross-env NODE_OPTIONS=--experimental-require-module next build",
    "start": "cross-env NODE_OPTIONS=--experimental-require-module next start",
    "lint": "eslint",
    "sft:data:security": "npx tsx scripts/prepare-security-dataset.ts",
    "sft:data:correctness": "npx tsx scripts/prepare-correctness-dataset.ts",
    "sft:data:readability": "npx tsx scripts/prepare-readability-dataset.ts",
    "sft:data": "npm run sft:data:security && npm run sft:data:correctness && npm run sft:data:readability",
    "sft:upload": "npx tsx scripts/upload-datasets.ts",
    "sft:launch": "npx tsx scripts/launch-sft.ts",
    "sft:evaluate": "npx tsx scripts/evaluate.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@google/genai": "^2.9.0",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^22.0.1",
    "d3-scale": "^4.0.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3-scale": "^4.0.9",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
